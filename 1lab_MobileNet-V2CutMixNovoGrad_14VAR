        "import torch\n",
        "\n",
        "from torchvision import datasets\n",
        "from torchvision.transforms import v2\n",
        "from torch.utils.data import DataLoader, random_split\n",
        "import matplotlib.pyplot as plt\n",
        "from google.colab import drive\n",
        "import torch.nn as nn\n",
        "from torchvision import models\n",
        "# Подготовка трансформаций (MobileNetV2 ждет размер 224x224)\n",
        "basic_transforms = v2.Compose([\n",
        "    v2.ToImage(),\n",
        "    v2.Resize((224, 224), antialias=True),\n",
        "    v2.ToDtype(torch.float32, scale=True),\n",
        "    # Стандартная нормализация для моделей ImageNet\n",
        "    v2.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "# Путь к папке Images\n",
        "data_dir = '/content/dataset/images/Images'\n",
        "\n",
        "# Загружаем весь датасет\n",
        "full_dataset = datasets.ImageFolder(root=data_dir, transform=basic_transforms)\n",
        "\n",
        "# Разбиваем на обучающую (80%) и тестовую (20%) выборки\n",
        "train_size = int(0.8 * len(full_dataset))\n",
        "test_size = len(full_dataset) - train_size\n",
        "train_dataset, test_dataset = random_split(full_dataset, [train_size, test_size])\n",
        "\n",
        "# Создаем загрузчики данных\n",
        "BATCH_SIZE = 32\n",
        "train_loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True)\n",
        "test_loader = DataLoader(test_dataset, batch_size=BATCH_SIZE, shuffle=False)\n",
        "\n",
        "print(f\"Всего классов: {len(full_dataset.classes)}\")\n",
        "print(f\"Картинок для обучения: {len(train_dataset)}\")\n",
        "\n",
        "\n",
        "# Инициализация CutMix для 120 классов\n",
        "cutmix = v2.CutMix(num_classes=120)\n",
        "\n",
        "# Пример получения батча и применения CutMix в цикле обучения\n",
        "images, labels = next(iter(train_loader))\n",
        "mixed_images, mixed_labels = cutmix(images, labels)\n",
        "\n",
        "print(\"Форма картинок после CutMix:\", mixed_images.shape) # Будет [32, 3, 224, 224]\n",
        "print(\"Форма меток после CutMix:\", mixed_labels.shape)    # Будет [32, 120]\n",
        "\n",
        "model = models.mobilenet_v2(weights='IMAGENET1K_V1')\n",
        "print(model.classifier)\n",
        "\n",
        "\n",
        "NUM_CLASSES = 120\n",
        "\n",
        "# Заменяем только последний слой\n",
        "model.classifier[1] = nn.Linear(\n",
        "    in_features=model.classifier[1].in_features,  # 1280\n",
        "    out_features=NUM_CLASSES\n",
        ")\n",
        "\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "model = model.to(device)\n",
        "print(f\"Обучение на: {device}\")\n",
        "\n",
        "\n",
        "# CrossEntropyLoss поддерживает soft-labels (после CutMix) начиная с PyTorch 1.10\n",
        "criterion = nn.CrossEntropyLoss()\n",
        "\n",
        "# Оптимизатор Adam\n",
        "optimizer = torch.optim.Adam(model.parameters(), lr=1e-4)\n",
        "\n",
        "from torchvision.transforms import v2\n",
        "\n",
        "NUM_EPOCHS = 5\n",
        "cutmix = v2.CutMix(num_classes=NUM_CLASSES)\n",
        "\n",
        "for epoch in range(NUM_EPOCHS):\n",
        "    model.train()\n",
        "    running_loss = 0.0\n",
        "\n",
        "    for images, labels in train_loader:\n",
        "        images, labels = images.to(device), labels.to(device)\n",
        "\n",
        "        # Применяем CutMix к батчу — метки становятся soft (вектор 120 значений)\n",
        "        images, labels = cutmix(images, labels)\n",
        "\n",
        "        optimizer.zero_grad()\n",
        "\n",
        "        outputs = model(images)\n",
        "        loss = criterion(outputs, labels)  # labels здесь float-тензор [batch, 120]\n",
        "\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "\n",
        "        running_loss += loss.item()\n",
        "\n",
        "    avg_loss = running_loss / len(train_loader)\n",
        "    print(f\"Epoch [{epoch+1}/{NUM_EPOCHS}] | Loss: {avg_loss:.4f}\")\n"
      ]
